# Database Configuration
MONGODB_URI=mongodb://localhost:27017/elowell-ecommerce

# JWT Configuration
JWT_SECRET=elowell-secret-key-2024-change-this-in-production

# Server Configuration
PORT=3000
NODE_ENV=development

# Google OAuth Configuration (for server-side verification)
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Payment Configuration (Razorpay)
RAZORPAY_KEY_ID=your-razorpay-key-id-here
RAZORPAY_KEY_SECRET=your-razorpay-key-secret-here

# Email Configuration (Nodemailer SMTP)
# For Gmail: Use App Password, not regular password
# Enable 2FA and generate App Password at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM_EMAIL=your-email@gmail.com

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880