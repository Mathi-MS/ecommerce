# Copy this file to .env and fill in your actual values

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/elowell-ecommerce

# JWT Configuration - CHANGE THIS IN PRODUCTION!
JWT_SECRET=elowell-secret-key-2024-change-this-in-production

# Server Configuration
PORT=3000
NODE_ENV=development

# Google OAuth Configuration (for server-side verification)
# Get these from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your-google-oauth-client-id-here
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret-here

# Payment Configuration (Razorpay)
# Get these from Razorpay Dashboard > Settings > API Keys
RAZORPAY_KEY_ID=your-razorpay-key-id-here
RAZORPAY_KEY_SECRET=your-razorpay-key-secret-here

# Email Configuration (Nodemailer SMTP)
# 
# For Gmail (Recommended):
# 1. Enable 2-Factor Authentication on your Google account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use the 16-character app password (not your regular password)
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
#
# For other providers:
# Outlook: smtp-mail.outlook.com, port 587
# Yahoo: smtp.mail.yahoo.com, port 587
# Custom SMTP: contact your email provider for settings

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880